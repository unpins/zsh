     Cmdnam cn;
     char *s, buf[PATH_MAX+1];
     char **pq;
+#ifdef __COSMOCC__
+    /* On Windows, allow a bare name to resolve to its ".exe" sibling     *
+     * (mirroring PATHEXT): when DIR/arg0 is absent, retry DIR/arg0.exe.  *
+     * If the ".exe" variant is the one that exists, the resolved path    *
+     * must carry ".exe" all the way to zexecve, so we hash the node as   *
+     * a HASHED entry holding the full ".exe" path in cn->u.cmd rather    *
+     * than letting execute()/findcmd() rebuild DIR/arg0 from the bare    *
+     * name.                                                              */
+    int found_exe = 0;
+    size_t arg0len = strlen(arg0);
+    int has_exe = (arg0len >= 4 && !strcmp(arg0 + arg0len - 4, ".exe"));
+#endif

