@@ -814,6 +835,23 @@
 		strucpy(&z, *pp);
 		*z++ = '/';
 		strcpy(z, arg0);
+#ifdef __COSMOCC__
+		/* Relative $path dir: candidate is *pp/arg0 in buf.  On     *
+		 * Windows, if that file is absent but its ".exe" sibling    *
+		 * exists, append ".exe" so the path that reaches zexecve    *
+		 * carries the suffix (mirrors the absolute-dir handling in  *
+		 * hashcmd()).  (z - buf) is the prefix length already       *
+		 * written; bound the append against MAXCMDLEN.              */
+		if (!iscom(buf)) {
+		    size_t cl = z - buf + strlen(arg0);
+		    if (!(cl >= 4 && !strcmp(buf + cl - 4, ".exe")) &&
+			cl + 4 < MAXCMDLEN) {
+			strcat(buf, ".exe");
+			if (!iscom(buf))
+			    buf[cl] = '\0';
+		    }
+		}
+#endif
 		ee = zexecve(buf, argv, newenvp);
