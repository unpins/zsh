@@ -806,6 +806,27 @@
 	}
 	for (pp = path; *pp; pp++)
 	    if (!(*pp)[0] || ((*pp)[0] == '.' && !(*pp)[1])) {
+#ifdef __COSMOCC__
+		/* Relative ("." or empty) $path element: zsh never hashes  *
+		 * these, so this loop is the only resolution path.  On      *
+		 * Windows, retry arg0's ".exe" sibling so a bare `ls` finds *
+		 * `ls.exe` in the current directory.  iscom() guards the    *
+		 * retry; we only divert to the ".exe" name when it exists.  */
+		{
+		    size_t a0l = strlen(arg0);
+		    if (!(a0l >= 4 && !strcmp(arg0 + a0l - 4, ".exe")) &&
+			a0l + 4 < MAXCMDLEN) {
+			strcpy(buf, arg0);
+			strcat(buf, ".exe");
+			if (iscom(buf)) {
+			    ee = zexecve(buf, argv, newenvp);
+			    if (isgooderr(ee, *pp))
+				eno = ee;
+			    continue;
+			}
+		    }
+		}
+#endif
 		ee = zexecve(arg0, argv, newenvp);
